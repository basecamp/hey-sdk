    "method": "DELETE",
    "path": "/calendar/todos/{todoId}",
    "pathParams": {
      "todoId": 12345
    },
    "mockResponses": [
      {
        "status": 503
      },
      {
        "status": 204
      }
    ],
    "assertions": [
      {
        "type": "requestCount",
        "expected": 2
      },
      {
        "type": "noError"
      }
    ],
    "tags": [
      "idempotent",
      "delete",
      "retry"
    ]
  },
