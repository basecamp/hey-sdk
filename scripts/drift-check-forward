#!/usr/bin/env bash
# drift-check-forward
#
# For each {method, path} in route-coverage.json, verify a matching entry
# exists in route-snapshot.json. Normalizes path parameter styles so that
# both {paramName} and :paramName match.
#
# Exit codes:
#   0 = All modeled routes present in snapshot
#   1 = Missing routes detected or snapshot empty

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

COVERAGE_FILE="$ROOT_DIR/spec/route-coverage.json"
SNAPSHOT_FILE="$ROOT_DIR/spec/route-snapshot.json"

if [ ! -f "$COVERAGE_FILE" ]; then
  echo "ERROR: $COVERAGE_FILE not found."
  exit 1
fi

if [ ! -f "$SNAPSHOT_FILE" ]; then
  echo "ERROR: $SNAPSHOT_FILE not found."
  exit 1
fi

# Empty snapshot: hard fail — must populate before checking
if jq -e 'length == 0' "$SNAPSHOT_FILE" > /dev/null 2>&1; then
  echo "ERROR: route-snapshot.json is empty. Run 'make drift-regen HAYSTACK_DIR=~/Work/basecamp/haystack' to populate."
  exit 1
fi

# Normalize a path for matching:
# - Lowercase method
# - Convert :param to {param}
# - Replace any {paramName} with {_} so different param names match
# - Strip trailing .json (so /boxes.json and /boxes match)
normalize() {
  local method path
  method=$(echo "$1" | tr '[:upper:]' '[:lower:]')
  # Replace :word with {word}
  path=$(echo "$2" | sed -E 's/:([a-zA-Z_][a-zA-Z0-9_]*)/{\1}/g')
  # Generalize all param segments to {_}
  path=$(echo "$path" | sed -E 's/\{[^}]+\}/{_}/g')
  # Strip .json suffix
  path=$(echo "$path" | sed -E 's/\.json$//')
  echo "$method $path"
}

# Build a lookup set from route-snapshot.json
declare -A snapshot_set
while IFS=$'\t' read -r method path; do
  key=$(normalize "$method" "$path")
  snapshot_set["$key"]=1
done < <(jq -r '.[] | [.method, .path] | @tsv' "$SNAPSHOT_FILE")

missing=0
total=0

while IFS=$'\t' read -r method path opId; do
  total=$((total + 1))
  key=$(normalize "$method" "$path")
  if [ -z "${snapshot_set[$key]+x}" ]; then
    echo "MISSING: $method $path ($opId)"
    missing=$((missing + 1))
  fi
done < <(jq -r '.[] | [.method, .path, .operationId] | @tsv' "$COVERAGE_FILE")

echo ""
echo "Checked $total modeled routes against snapshot."

if [ "$missing" -gt 0 ]; then
  echo "$missing route(s) not found in route-snapshot.json."
  echo ""
  echo "Either:"
  echo "  - The route was removed from haystack (update the Smithy model)"
  echo "  - The snapshot is stale (run 'make drift-regen')"
  exit 1
fi

echo "All modeled routes present in snapshot."
exit 0
